provider_installation {
  filesystem_mirror {
    path    = "/usr/local/share/terraform/plugins"
    include = [
      "registry.terraform.io/hashicorp/local",
      "registry.terraform.io/hashicorp/null",
      "registry.terraform.io/hashicorp/random"
    ]
  }
  direct {
    exclude = ["registry.terraform.io/*/*"]
  }
}
