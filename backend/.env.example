# Copy to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500"]

# Auth (Phase 1: set to true to skip authentication)
AUTH_DISABLED=true

# Azure AD B2C (Phase 2: set AUTH_DISABLED=false and fill these in)
AZURE_TENANT_NAME=terraformageddon
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-backend-client-id
AZURE_B2C_FLOW=B2C_1_susi

# Database
DATABASE_URL=sqlite+aiosqlite:///./terraformageddon.db
# For Phase 2 PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/terraformageddon

# Docker
SANDBOX_IMAGE=terraformageddon-sandbox:latest
SESSION_TIMEOUT_MINUTES=15
WORKSPACE_BASE_DIR=/tmp/tg-sessions

# Security
MAX_SESSIONS_PER_USER=3
MAX_RUNS_PER_MINUTE=30
MAX_WORKSPACE_SIZE_MB=50
